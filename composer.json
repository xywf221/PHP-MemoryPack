{
    "name": "memory-pack/php-memory-pack",
    "description": "Small PHP reader/writer for the core Cysharp MemoryPack binary format.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "MemoryPack\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MemoryPack\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.4"
    },
    "require-dev": {
        "pestphp/pest": "^3.0 || ^4.0"
    },
    "scripts": {
        "test": "vendor/bin/pest"
    },
    "repositories": [{
        "name": "packagist.org",
        "type": "composer",
        "url": "https://repo.packagist.org"
    }],
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
